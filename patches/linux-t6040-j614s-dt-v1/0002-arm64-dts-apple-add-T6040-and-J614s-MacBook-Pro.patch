+
+		/*
+		 * MTP carries the internal keyboard and trackpad over DockChannel.
+		 * All addresses and IRQs below are from the J614s ADT. Keep the
+		 * complete path disabled in the SoC description; the board-level
+		 * bring-up DT enables it as one deliberately gated unit.
+		 */
+		mtp_mbox: mailbox@514608000 {
+			compatible = "apple,t8140-asc-mailbox", "apple,asc-mailbox-v4";
+			reg = <0x5 0x14608000 0x0 0x4000>;
+			interrupt-parent = <&aic>;
+			/*
+			 * The ADT lists these as [793 792 795 794]: Apple's ADT
+			 * convention is not-empty first in each pair. The
+			 * binding (and the actual lines, ascending) are
+			 * empty/not-empty — verified against every other ASC
+			 * node in the J614s ADT (all follow [n+1 n n+3 n+2]).
+			 */
+			interrupts = <AIC_IRQ 792 IRQ_TYPE_LEVEL_HIGH>,
+				     <AIC_IRQ 793 IRQ_TYPE_LEVEL_HIGH>,
+				     <AIC_IRQ 794 IRQ_TYPE_LEVEL_HIGH>,
+				     <AIC_IRQ 795 IRQ_TYPE_LEVEL_HIGH>;
+			interrupt-names = "send-empty", "send-not-empty",
