+			reg = <0x5 0x14b14000 0x0 0x1000>,
+			      <0x5 0x14b30000 0x0 0x1000>,
+			      <0x5 0x14b34000 0x0 0x1000>;
+			reg-names = "irq", "config", "data";
+			interrupt-parent = <&aic>;
