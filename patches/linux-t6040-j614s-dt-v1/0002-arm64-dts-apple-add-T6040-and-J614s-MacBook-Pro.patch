+		};
+
+		pmgr1: power-management@502280000 {
+			compatible = "apple,t6041-pmgr", "apple,t8103-pmgr", "syscon", "simple-mfd";
+			#address-cells = <1>;
+			#size-cells = <1>;
+			reg = <0x5 0x02280000 0 0x14000>;
