 arch/arm64/boot/dts/apple/t6040-j614s.dts |   53 +
 arch/arm64/boot/dts/apple/t6040-pmgr.dtsi | 1971 +++++++++++++++++++++
 arch/arm64/boot/dts/apple/t6040.dtsi      |  405 +++++
 4 files changed, 2430 insertions(+)
