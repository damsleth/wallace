From b9e755babc34545e3cf1d1f90e9c4e45b31e5b2f Mon Sep 17 00:00:00 2001
From: CJ Damsleth <kim@damsleth.no>
Date: Thu, 23 Jul 2026 23:38:47 +0200
Subject: [RFC PATCH v1 3/4] arm64: dts: apple: add J614s keyboard and trackpad
 variant

Add a board variant which enables the MTP DART, DockChannel mailbox, and
HID consumer.  Name the J614s-specific multitouch firmware so userspace
can install it without relying on a generic fallback.

Signed-off-by: CJ Damsleth <kim@damsleth.no>
---
 arch/arm64/boot/dts/apple/Makefile            |  1 +
 arch/arm64/boot/dts/apple/t6040-j614s-kbd.dts | 62 +++++++++++++++++++
 2 files changed, 63 insertions(+)
 create mode 100644 arch/arm64/boot/dts/apple/t6040-j614s-kbd.dts

diff --git a/arch/arm64/boot/dts/apple/Makefile b/arch/arm64/boot/dts/apple/Makefile
index 096925e2055e..02ab4d6de35d 100644
--- a/arch/arm64/boot/dts/apple/Makefile
+++ b/arch/arm64/boot/dts/apple/Makefile
@@ -87,6 +87,7 @@ dtb-$(CONFIG_ARCH_APPLE) += t6001-j375c.dtb
 dtb-$(CONFIG_ARCH_APPLE) += t6002-j375d.dtb
 dtb-$(CONFIG_ARCH_APPLE) += t6022-j180d.dtb
 dtb-$(CONFIG_ARCH_APPLE) += t6040-j614s.dtb
+dtb-$(CONFIG_ARCH_APPLE) += t6040-j614s-kbd.dtb
 dtb-$(CONFIG_ARCH_APPLE) += t6020-j414s.dtb
 dtb-$(CONFIG_ARCH_APPLE) += t6021-j414c.dtb
 dtb-$(CONFIG_ARCH_APPLE) += t6020-j416s.dtb
diff --git a/arch/arm64/boot/dts/apple/t6040-j614s-kbd.dts b/arch/arm64/boot/dts/apple/t6040-j614s-kbd.dts
new file mode 100644
index 000000000000..fd720e1d8b1b
--- /dev/null
+++ b/arch/arm64/boot/dts/apple/t6040-j614s-kbd.dts
@@ -0,0 +1,62 @@
+// SPDX-License-Identifier: GPL-2.0+ OR MIT
+/*
+ * Apple MacBook Pro J614s keyboard bring-up variant.
+ *
+ * This keeps the proven framebuffer console decoupled from PMGR and enables
+ * only the ADT-derived MTP/DockChannel path needed by the internal HID devices.
+ */
+/dts-v1/;
+
+#include "t6040.dtsi"
+
+/ {
+	compatible = "apple,j614s", "apple,t6040", "apple,arm-platform";
+	model = "Apple MacBook Pro (M4 Pro) J614s [DockChannel HID bring-up]";
+
+	aliases {
+		keyboard = &mtp_keyboard;
+	};
+
+	chosen {
+		#address-cells = <2>;
+		#size-cells = <2>;
+		ranges;
+
+		framebuffer0: framebuffer@0 {
+			compatible = "apple,simple-framebuffer", "simple-framebuffer";
+			reg = <0 0 0 0>; /* To be filled by loader */
+			status = "disabled";
+		};
+	};
+
+	reserved-memory {
+		#address-cells = <2>;
+		#size-cells = <2>;
+		ranges;
+	};
+
+	memory@10000000000 {
+		device_type = "memory";
+		reg = <0x100 0 0x0 0>; /* To be filled by loader */
+	};
+};
+
+&mtp_mbox {
+	status = "okay";
+};
+
+&mtp_dart {
+	status = "okay";
+};
+
+&mtp_dockchannel {
+	status = "okay";
+};
+
+&mtp_hid {
+	status = "okay";
+
+	multi-touch {
+		firmware-name = "apple/tpmtfw-j614s.bin";
+	};
+};
-- 
